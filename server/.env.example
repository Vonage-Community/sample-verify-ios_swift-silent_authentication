VONAGE_APPLICATION_ID=
VONAGE_PRIVATE_KEY_PATH=./private.key
PORT=4000
# Public URL for Vonage webhooks (e.g. your ngrok URL, no trailing slash)
NGROK_URL=
# Seconds before Vonage abandons a channel and moves to the next one (15–900).
# The server mirrors this clock to drive UI updates — keep it short for demos.
CHANNEL_TIMEOUT_SECONDS=60
